---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import News from "../components/News.astro";
import { publicationList } from "../content/publication";
import PublicationBlock from "../components/PublicationBlock.astro";

const grouped = {
  conference: publicationList.filter((p) => p.type === "conference"),
  short: publicationList.filter((p) => p.type === "short"),
  arxiv: publicationList.filter((p) => p.type === "arxiv"),
};
---

<Layout title="Heechan Lee">
  <div class="introduction">
    <div class="intro-paragraph">
      <h1>Heechan Lee, 이희찬</h1>
      <p>
        I'm a Master's student in the <a href="https://cs.kaist.ac.kr/" target="_blank">School of Computing</a> at <a href="https://www.kaist.ac.kr/" target="_blank">KAIST</a>.
        I'm working in <a href="https://cstlab.org/" target="_blank">Collaborative Social Technologies Lab(CSTL)</a> and <a href="https://www.kixlab.org" target="_blank">KAIST Interaction Lab(KIXLAB)</a>, where I'm advised by <a href="https://joseph.seering.org/" target="_blank">Prof. Joseph Seering</a> and <a href="https://juhokim.com/" target="_blank">Prof. Juho Kim</a>.
        <br />
        <br />
        I am interested in <b>Human-AI Interaction</b> and <b>Human-centered AI</b>.
        My research aims to support <b>dynamic alignment</b> between humans and AI agents, grounded in mutual <b>understanding</b> and <b>structuring</b>.
        I approach this from two complementary directions: (1) <i>from the human's perspective</i>, by building interactive interfaces that help people understand, evaluate, and strcuture actionable feedback on AI behavior, and (2) <i>from the AI's perspective</i>, by improving its ability to understand user intent and context and to strcuture what actions to take.
        I'm excited to explore how we can design the collaboration betwen humans and AI agents, with interface implementation and data-centric approaches!
      </p>
    </div>
    <img class="main" src="/assets/img/main.JPG" />
  </div>
  <div class="contacts">
    <a href="mailto::hclee99@kaist.ac.kr"><img src="/assets/img/mail_icon.svg" class="contact-icon" /></a>
    <a href="https://github.com/Gabul99" target="_blank"><img src="/assets/img/github.svg" class="contact-icon" /></a>
    <a href="https://www.linkedin.com/in/heechan-lee-0108a5217/" target="_blank"><img src="/assets/img/linkedin.svg" class="contact-icon" /></a>
    <a href="https://x.com/heechanleekr" target="_blank"><img src="/assets/img/x.svg" class="contact-icon" /></a>
    <a href="https://scholar.google.com/citations?user=O6BiJGkAAAAJ&hl=en" target="_blank"><img src="/assets/img/google-scholar.svg" class="contact-icon" /></a>
    <a href="https://medium.com/hcleedev" target="_blank" style={{height: 'fit-content'}}>Blog (in Kor)</a>
  </div>
  <News />
  <h3 class="pub-title">Publications</h3>
  <p class="pub-hint">(* equal contribution)</p>
  <div class="pub-list">
    {grouped.arxiv.length > 0 && (
    <>
      <h2 class="section-title">Preprint & In submission</h2>
      {grouped.arxiv.map((p) => (
        <PublicationBlock publication={p} />
      ))}
    </>
  )}
    {grouped.conference.length > 0 && (
    <>
      <h2 class="section-title">Conference Paper</h2>
      {grouped.conference.map((p) => (
        <PublicationBlock publication={p} />
      ))}
    </>
  )}

  {grouped.short.length > 0 && (
    <>
      <h2 class="section-title">Workshop, Poster, Short paper</h2>
      {grouped.short.map((p) => (
        <PublicationBlock publication={p} />
      ))}
    </>
  )}
  </div>
  <section class="youtube-playlist">
    <h3 class="playlist-title">Playlist</h3>
    <div class="video-wrapper">
      <iframe
        width="560"
        height="315"
        src="https://www.youtube.com/embed/videoseries?si=UHhpBpUShk_KcQwD&amp;list=PLunqp0JC2kNlo0Jn_VHM6Xv6RVz1-yM6a"
        title="YouTube video player"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen
      ></iframe>
    </div>
  </section>
</Layout>
<style>
  img.main {
    width: 240px;
    height: auto;
    align-self: flex-start;
    object-fit: contain;
  }

  div.introduction {
    width: 100%;
    height: fit-content;
    display: flex;
    flex-direction: row;
    gap: 16px;

    .intro-paragraph {
      display: flex;
      flex-direction: column;
    }
  }

  div.contacts {
    width: 100%;
    display: flex;
    flex-direction: row;
    gap: 8px;
    align-items: center;
  }

  div.pub-list {
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 8px;
  }

  h2.section-title {
    all: unset;
    font-size: 14px;
    font-weight: 600;
    margin-top: 8px;
  }

  img.contact-icon {
    all: unset;
    width: 32px;
    height: 32px;
    cursor: pointer;
  }
  img.contact-icon:hover {
    opacity: 0.5;
  }

  h3.pub-title {
    margin-bottom: 4px;
  }

  p.pub-hint {
    margin: 0px;
  }

  section.youtube-playlist {
    width: 100%;
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border, #e5e5e5);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  h3.playlist-title {
    margin-bottom: 16px;
  }

  .video-wrapper {
    position: relative;
    width: 100%;
    max-width: 560px;
    aspect-ratio: 16 / 9;
  }

  .video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  @media (max-width: 768px) {
    img.main {
      display: none;
    }
  }

</style>